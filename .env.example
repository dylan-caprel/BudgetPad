# ============================================================
# Configuration BudgetPAD - exemple
# Copiez ce fichier en `.env` et adaptez les valeurs.
# ============================================================

# --- Django ---
SECRET_KEY=changez-moi-en-une-cle-aleatoire-de-50-caracteres-minimum
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Bascule entre les settings : 'dev' | 'prod'
DJANGO_ENV=dev

# --- Base de donnees (MySQL recommande) ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=budgetpad
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ============================================================
# Production uniquement (DJANGO_ENV=prod)
# ============================================================

# URL admin obfusquee (defaut: admin/)
ADMIN_URL=admin/

# Origines CSRF de confiance (separateur virgule, schema inclus)
# Ex: https://budgetpad.pad.cm,https://www.budgetpad.pad.cm
CSRF_TRUSTED_ORIGINS=

# --- Sentry (optionnel) ---
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# APP_VERSION=budgetpad@1.0.0
